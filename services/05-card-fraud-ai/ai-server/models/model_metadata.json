{
  "project": "04-card-fraud-ai",
  "service_name": "Card Fraud Detection AI",
  "dataset": "PaySim",
  "data_file": "paysim.csv",
  "model_name": "Random Forest (balanced)",
  "model_version": "1.0.0",
  "target": "isFraud",
  "input_features": [
    "type",
    "amount",
    "oldbalanceOrg",
    "oldbalanceDest",
    "Hour"
  ],
  "engineered_features": [
    "TimeOfDay",
    "AmountLog",
    "AmountToSenderBalance",
    "AmountToReceiverBalance",
    "SenderBalanceAfterEstimated",
    "ReceiverBalanceAfterEstimated",
    "IsSenderBalanceZero",
    "IsLargeTransaction",
    "IsTransfer",
    "IsCashOut",
    "BalanceDifference"
  ],
  "threshold": 0.5,
  "metrics": {
    "accuracy": 0.999997,
    "precision": 1.0,
    "recall": 0.997565,
    "f1": 0.998781,
    "roc_auc": 0.999642,
    "pr_auc": 0.997793
  },
  "train_rows": 5090096,
  "test_rows": 1272524,
  "fraud_ratio_percent": 0.129082,
  "random_state": 42
}